# Production assets are fingerprinted and immutable, cache aggressively for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Main HTML document should always verify freshness
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Configuration and public metadata
/site.webmanifest
  Cache-Control: public, max-age=86400, must-revalidate
/sitemap.xml
  Cache-Control: public, max-age=0, must-revalidate
/robots.txt
  Cache-Control: public, max-age=0, must-revalidate

# Graphic assets and branding
/favicon.ico
  Cache-Control: public, max-age=86400, must-revalidate
/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate
/og-image.png
  Cache-Control: public, max-age=86400, must-revalidate
