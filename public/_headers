# By default, force all HTML pages to revalidate freshness on every visit (prevent browser caching old index.html copies)
/*
  Cache-Control: public, max-age=0, must-revalidate

# Production assets are fingerprinted and immutable, cache aggressively for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Configuration and public metadata
/site.webmanifest
  Cache-Control: public, max-age=86400, must-revalidate

# Graphic assets and branding
/favicon.ico
  Cache-Control: public, max-age=86400, must-revalidate
/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate
/og-image.png
  Cache-Control: public, max-age=86400, must-revalidate
